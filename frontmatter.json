{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.framework.id": "astro",
  "frontMatter.content.defaultFileType": "mdx",
  "frontMatter.global.disabledNotifications": ["requiredFieldValidation"],
  "frontMatter.content.pageFolders": [
    {
      "title": "Posts",
      "path": "[[workspace]]/src/content/posts",
      "contentTypes": ["posts"]
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "posts",
      "fileType": "mdx",
      "pageBundle": false,
      "previewPath": "",
      "filePrefix": "{{date}}-",
      "fields": [
        {
          "name": "title",
          "title": "Titolo",
          "type": "string"
        },
        {
          "name": "date",
          "title": "Data",
          "type": "datetime",
          "isPublishDate": true
        },
        {
          "name": "excerpt",
          "title": "Estratto",
          "type": "string"
        },
        {
          "name": "seoDescription",
          "title": "SEO Description",
          "type": "string"
        },
        {
          "name": "categories",
          "title": "Categorie",
          "type": "categories"
        },
        {
          "name": "tags",
          "title": "Tag",
          "type": "tags"
        },
        {
          "name": "featuredImage",
          "title": "Immagine in evidenza",
          "type": "image"
        },
        {
          "name": "featuredImageAlt",
          "title": "Alt immagine",
          "type": "string"
        },
        {
          "name": "car_week",
          "title": "Settimana (es. W40)",
          "type": "string"
        },
        {
          "name": "car_km",
          "title": "Km totali",
          "type": "string"
        },
        {
          "name": "car_race",
          "title": "È una gara",
          "type": "boolean"
        },
        {
          "name": "training_types",
          "title": "Tipo allenamento per uscita (🟢 🟡 🔴 🏁 — una per uscita, ripetibili)",
          "type": "list"
        },
        {
          "name": "training_feelings",
          "title": "Sensazioni per uscita (🙂 😀 😐 🫤 🙁 😭 ☠️ 🏁 — una per uscita, ripetibili)",
          "type": "list"
        },
        {
          "name": "places",
          "title": "Luoghi",
          "type": "string"
        },
        {
          "name": "wpId",
          "title": "WordPress ID",
          "type": "number"
        }
      ]
    }
  ]
}