---
interface Props {
  categories: string[];
  car_race?: boolean;
  isListing?: boolean;
}
const { categories, car_race = false, isListing = false } = Astro.props;

const isRunning = categories.some(c =>
  ['running', 'sport', 'corsa', 'allenamento'].includes(c.toLowerCase())
);
const cat = categories[0] ?? '';
---
{isRunning ? (
  <span class="running-badge running-badge--minimal" data-post-type="running">
    <svg class="running-badge__icon" viewBox="0 0 24 24" width="16" height="16">
      <path fill="currentColor" d="M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l1-4.4 2.1 2v6h2v-7.5l-2.1-2 .6-3c1.3 1.5 3.3 2.5 5.5 2.5v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1-.3 0-.5.1-.8.1L9 7.1c-.2.1-.3.3-.3.5s.1.4.3.5l1.8.9.6 3.1-1.8.7c-.1.1-.1.2-.1.3 0 .1 0 .2.1.3l2.2 3.9 1.7-1z"/>
    </svg>
    <span class="running-badge__text">Running</span>
  </span>
) : cat ? (
  <a href={`/categoria/${cat.toLowerCase()}/`} class="car-badge car-badge--dev">
    {cat.toUpperCase()}
  </a>
) : null}
{isListing && car_race && (
  <span class="car-badge car-badge--race">🏆</span>
)}
