---
interface Props {
  training_types?: string[];
  training_feelings?: string[];
}
const { training_types, training_feelings } = Astro.props;

if (!training_types?.length && !training_feelings?.length) return;

const types    = training_types    ?? [];
const feelings = training_feelings ?? [];
const count    = Math.max(types.length, feelings.length);

const typeMap: Record<string, 'good' | 'ok' | 'bad'> = {
  '🟢': 'good', '🏁': 'good',
  '🟡': 'ok',
  '🔴': 'bad',
};

const items = Array.from({ length: count }, (_, i) => ({
  type:    types[i]    ?? '',
  feeling: feelings[i] ?? '',
  quality: typeMap[types[i]] ?? 'ok',
})).filter(item => item.type || item.feeling);
---
{items.length > 0 && (
  <div class="car-training-log">
    <div class="car-training-log__label">Training Log</div>
    <div class="car-training-log__items">
      {items.map(({ type, feeling, quality }) => (
        <div
          class={`car-training-log__item car-training-log__item--${quality}`}
          title={`${type} ${feeling}`.trim()}
        >
          <span class={`car-training-log__dot car-training-log__dot--${quality}`}></span>
          {feeling && <span class="car-training-log__feeling">{feeling}</span>}
        </div>
      ))}
    </div>
  </div>
)}
