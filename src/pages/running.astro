---
import Base from '../layouts/Base.astro';

// ── Fetch stats JSON da CDN (generato dal bottone "Aggiorna statistiche Running") ──
const STATS_URL = 'https://cdn.codeandrun.it/data/running-stats.json';

type YearTotal = { year: number; total_distance: number; elevation: number; count: number; total_moving: number; kudos: number };
type PersonalRecord = { name: string; distanceMeters: number; elapsedTime: number; startDate: string };
type StatsData = {
  updatedAt: string;
  yearTotals: YearTotal[];
  chartHeader: string[];
  chartRows: (string | number | null)[][];
  chartYears: number[];
  personalRecords: PersonalRecord[];
};

let stats: StatsData | null = null;
try {
  const res = await fetch(STATS_URL);
  if (res.ok) stats = await res.json();
} catch { /* fallback al contenuto statico */ }

// ── Helpers ───────────────────────────────────────────────────────────────────
function fmtTime(s: number): string {
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
  if (h > 0) return `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  return `${m}:${String(sec).padStart(2,'0')}`;
}
function fmtPace(dist: number, secs: number): string {
  const ppm = (secs / dist) * 1000;
  return `${Math.floor(ppm / 60)}:${String(Math.round(ppm % 60)).padStart(2,'0')}/km`;
}
function fmtMoving(s: number): string {
  return `${Math.floor(s / 3600)}h ${String(Math.floor((s % 3600) / 60)).padStart(2,'0')}m`;
}

const COLORS = ["#FC4C02","#1E3A8A","#10B981","#3B82F6","#FF7A3D","#6366F1","#F59E0B"];
const FEATURED_PR = ["5k","10k","15k","Half-Marathon","30k","Marathon"];

function buildPrHtml(records: PersonalRecord[]): string {
  if (!records.length) return '';
  const featured = records.filter(r => FEATURED_PR.includes(r.name));
  const rest = records.filter(r => !FEATURED_PR.includes(r.name));
  const cards = featured.map(pr => {
    const d = new Date(pr.startDate).toLocaleDateString('it-IT', { day:'numeric', month:'short', year:'numeric' });
    return `<div class="crst-pr-card">
  <div class="crst-pr-label">${pr.name}</div>
  <div class="crst-pr-time">${fmtTime(pr.elapsedTime)}</div>
  <div class="crst-pr-pace">${fmtPace(pr.distanceMeters, pr.elapsedTime)}</div>
  <div class="crst-pr-date">${d}</div>
</div>`;
  }).join('\n');
  const restRows = rest.map(pr => {
    const d = new Date(pr.startDate).toLocaleDateString('it-IT', { day:'numeric', month:'short', year:'numeric' });
    return `<tr><td>${pr.name}</td><td class="r">${fmtTime(pr.elapsedTime)}</td><td class="m">${fmtPace(pr.distanceMeters, pr.elapsedTime)}</td><td class="m">${d}</td></tr>`;
  }).join('\n');
  const restTable = rest.length ? `<table class="crst-table" style="margin-top:12px"><thead><tr><th>Distanza</th><th class="r">Tempo</th><th class="r">Passo</th><th class="r">Data</th></tr></thead><tbody>${restRows}</tbody></table>` : '';
  return `<div class="crst"><div class="crst-pr-grid">${cards}</div>${restTable}</div>`;
}

function buildYearButtons(years: number[]): string {
  const hidden = new Set(years.slice(0, Math.max(0, years.length - 4)));
  return years.map((y, i) => {
    const c = COLORS[i % COLORS.length];
    const isHidden = hidden.has(y);
    const bg = isHidden ? 'transparent' : c;
    const fg = isHidden ? c : '#fff';
    return `<button id="btn-year-${y}" onclick="toggleYear(${i})" style="margin:0 4px 8px 0;padding:4px 14px;border-radius:99px;font-size:12px;font-weight:600;cursor:pointer;border:2px solid ${c};background:${bg};color:${fg};transition:all 0.15s">${y}</button>`;
  }).join('\n');
}

function buildTableHtml(yearTotals: YearTotal[]): string {
  const cur = new Date().getFullYear();
  const rows = yearTotals.map(y => {
    const cell = y.year === cur
      ? `<span class="crst-yc">${y.year}<span class="crst-badge">in corso</span></span>`
      : `<span class="crst-yn">${y.year}</span>`;
    return `<tr><td>${cell}</td><td class="r"><span class="crst-km">${(y.total_distance/1000).toFixed(0)}</span> <span style="color:#9ca3af;font-size:12px">km</span></td><td class="r">${y.elevation.toFixed(0)} <span style="color:#9ca3af;font-size:12px">m</span></td><td class="r">${y.count}</td><td class="m">${fmtMoving(y.total_moving)}</td><td class="m">${y.kudos}</td></tr>`;
  }).join('\n');
  return `<div class="crst" style="margin-top:24px"><table class="crst-table"><thead><tr><th>Anno</th><th class="r">Distanza</th><th class="r">Dislivello</th><th class="r">Attività</th><th class="r">Tempo</th><th class="r">Kudos</th></tr></thead><tbody>${rows}</tbody></table></div>`;
}

function buildChartDataJs(header: string[], rows: (string|number|null)[][]): string {
  const dataRows = rows.map(r => {
    const vals = r.slice(1).map(v => v === null ? 'null' : v).join(', ');
    return `      ['${r[0]}', ${vals}]`;
  }).join(',\n');
  return `[${JSON.stringify(header)},\n${dataRows}\n    ]`;
}

const updatedAt = stats?.updatedAt
  ? new Date(stats.updatedAt).toLocaleDateString('it-IT', { day:'numeric', month:'long', year:'numeric' })
  : '23 aprile 2026';
---
<Base title="Running — Code and Run" description="Statistiche di corsa, personal record e diari di allenamento.">
  <main class="car-main car-main--page" id="main">
    <article class="car-single">
      <div class="car-single__header car-container">
        <h1 class="car-single__title">Running</h1>
      </div>
      <div class="car-single__content car-container">

<style is:global>
.crst{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.crst-date{font-size:13px;color:#9ca3af;margin:0 0 8px}
.crst-table{width:100%;border-collapse:collapse;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.08)}
.crst-table th{padding:10px 16px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:#6b7280;background:#f9fafb;border-bottom:1px solid #e5e7eb}
.crst-table th.r{text-align:right}
.crst-table td{padding:11px 16px;border-bottom:1px solid #f3f4f6;font-size:14px;color:#111827}
.crst-table td.r{text-align:right;font-variant-numeric:tabular-nums}
.crst-table td.m{text-align:right;font-variant-numeric:tabular-nums;color:#6b7280}
.crst-pr-grid{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:0}
.crst-pr-card{display:inline-block;background:#f9fafb;border:1px solid #e5e7eb;border-radius:10px;padding:14px 20px;min-width:120px;text-align:center}
.crst-pr-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:#6b7280;margin-bottom:4px}
.crst-pr-time{font-size:22px;font-weight:700;color:#111827;line-height:1.2}
.crst-pr-pace{font-size:12px;color:#FC4C02;font-weight:600;margin-top:2px}
.crst-pr-date{font-size:11px;color:#9ca3af;margin-top:2px}
.crst-yn{font-weight:700;font-size:15px;color:#111827}
.crst-yc{font-weight:700;font-size:15px;color:#FC4C02}
.crst-badge{display:inline-block;margin-left:6px;font-size:10px;font-weight:600;background:#FC4C02;color:#fff;padding:1px 6px;border-radius:99px;vertical-align:middle}
.crst-km{font-weight:600}
.crst-chart-wrap{background:#fff;border-radius:10px;padding:8px}
.car-dark .crst-table th{color:#9ca3af;background:#1f2937;border-bottom:1px solid #374151}
.car-dark .crst-table td{border-bottom:1px solid #374151;color:#f9fafb}
.car-dark .crst-table td.m{color:#9ca3af}
.car-dark .crst-pr-card{background:#1f2937;border-color:#374151}
.car-dark .crst-pr-label{color:#9ca3af}
.car-dark .crst-pr-time{color:#f9fafb}
.car-dark .crst-yn{color:#f9fafb}
.car-dark .crst-chart-wrap{background:#111827}
</style>

<p class="crst crst-date"><em>Aggiornato il {updatedAt}</em></p>

{stats ? (
  <Fragment set:html={buildPrHtml(stats.personalRecords)} />
) : (
<div class="crst">
<div class="crst-pr-grid">
<div class="crst-pr-card"><div class="crst-pr-label">5k</div><div class="crst-pr-time">18:20</div><div class="crst-pr-pace">3:40/km</div><div class="crst-pr-date">14 mar 2024</div></div>
<div class="crst-pr-card"><div class="crst-pr-label">10k</div><div class="crst-pr-time">38:05</div><div class="crst-pr-pace">3:49/km</div><div class="crst-pr-date">1 dic 2024</div></div>
<div class="crst-pr-card"><div class="crst-pr-label">Half-Marathon</div><div class="crst-pr-time">1:24:57</div><div class="crst-pr-pace">4:02/km</div><div class="crst-pr-date">15 feb 2026</div></div>
<div class="crst-pr-card"><div class="crst-pr-label">Marathon</div><div class="crst-pr-time">3:04:28</div><div class="crst-pr-pace">4:22/km</div><div class="crst-pr-date">15 mar 2026</div></div>
</div>
</div>
)}

{stats ? (
  <Fragment set:html={`<div class="crst" style="margin-top:24px;margin-bottom:4px">${buildYearButtons(stats.chartYears)}</div>`} />
) : (
<div class="crst" style="margin-top:24px;margin-bottom:4px">
