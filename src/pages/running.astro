<button id="btn-year-2023" onclick="toggleYear(12)" style="margin:0 4px 8px 0;padding:4px 14px;border-radius:99px;font-size:12px;font-weight:600;cursor:pointer;border:2px solid #6366F1;background:#6366F1;color:#fff;transition:all 0.15s">2023</button>
<button id="btn-year-2024" onclick="toggleYear(13)" style="margin:0 4px 8px 0;padding:4px 14px;border-radius:99px;font-size:12px;font-weight:600;cursor:pointer;border:2px solid #F59E0B;background:#F59E0B;color:#fff;transition:all 0.15s">2024</button>
<button id="btn-year-2025" onclick="toggleYear(14)" style="margin:0 4px 8px 0;padding:4px 14px;border-radius:99px;font-size:12px;font-weight:600;cursor:pointer;border:2px solid #FC4C02;background:#FC4C02;color:#fff;transition:all 0.15s">2025</button>
<button id="btn-year-2026" onclick="toggleYear(15)" style="margin:0 4px 8px 0;padding:4px 14px;border-radius:99px;font-size:12px;font-weight:600;cursor:pointer;border:2px solid #1E3A8A;background:#1E3A8A;color:#fff;transition:all 0.15s">2026</button>
</div>
)}

<div class="crst-chart-wrap">
  <div id="running-stats-chart" style="width:100%;height:400px"></div>
</div>

{stats ? (
  <Fragment set:html={buildTableHtml(stats.yearTotals)} />
) : (
<div class="crst" style="margin-top:24px">
<table class="crst-table">
<thead><tr><th>Anno</th><th class="r">Distanza</th><th class="r">Dislivello</th><th class="r">Attività</th><th class="r">Tempo</th><th class="r">Kudos</th></tr></thead>
<tbody>
<tr><td><span class="crst-yc">2026<span class="crst-badge">in corso</span></span></td><td class="r"><span class="crst-km">963</span> <span style="color:#9ca3af;font-size:12px">km</span></td><td class="r">4151 <span style="color:#9ca3af;font-size:12px">m</span></td><td class="r">67</td><td class="m">77h 59m</td><td class="m">438</td></tr>
<tr><td><span class="crst-yn">2025</span></td><td class="r"><span class="crst-km">2617</span> <span style="color:#9ca3af;font-size:12px">km</span></td><td class="r">11690 <span style="color:#9ca3af;font-size:12px">m</span></td><td class="r">191</td><td class="m">215h 04m</td><td class="m">1015</td></tr>
<tr><td><span class="crst-yn">2024</span></td><td class="r"><span class="crst-km">3139</span> <span style="color:#9ca3af;font-size:12px">km</span></td><td class="r">14505 <span style="color:#9ca3af;font-size:12px">m</span></td><td class="r">227</td><td class="m">257h 36m</td><td class="m">667</td></tr>
<tr><td><span class="crst-yn">2023</span></td><td class="r"><span class="crst-km">1815</span> <span style="color:#9ca3af;font-size:12px">km</span></td><td class="r">8891 <span style="color:#9ca3af;font-size:12px">m</span></td><td class="r">159</td><td class="m">154h 05m</td><td class="m">1085</td></tr>
<tr><td><span class="crst-yn">2022</span></td><td class="r"><span class="crst-km">1928</span> <span style="color:#9ca3af;font-size:12px">km</span></td><td class="r">7633 <span style="color:#9ca3af;font-size:12px">m</span></td><td class="r">163</td><td class="m">157h 50m</td><td class="m">1040</td></tr>
</tbody>
</table>
</div>
)}

      </div>
    </article>
  </main>
</Base>

<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
<script type="text/javascript" is:inline define:vars={{ chartYears: stats?.chartYears, chartHeader: stats?.chartHeader, chartRows: stats?.chartRows }}>
  var _years = chartYears || [2011,2012,2013,2014,2015,2016,2017,2018,2019,2020,2021,2022,2023,2024,2025,2026];
  var _colors = ["#FC4C02","#1E3A8A","#10B981","#3B82F6","#FF7A3D","#6366F1","#F59E0B"];
  var _hidden = {};
  _years.forEach(function(year, i) { if (i < _years.length - 4) _hidden[i] = true; });
  var _chart, _data;

  function _isDark() { return document.documentElement.classList.contains('car-dark'); }

  function drawChart() {
    if (!_chart || !_data) return;
    var dark = _isDark();
    var textColor  = dark ? '#9ca3af' : '#6b7280';
    var gridColor  = dark ? '#374151' : '#f3f4f6';
    var baseColor  = dark ? '#374151' : '#e5e7eb';
    var titleColor = dark ? '#f9fafb' : '#111827';
    var bgColor    = dark ? '#111827' : '#ffffff';

    var visibleCols = [0];
    var seriesOpt = {};
    var si = 0;
    _years.forEach(function(year, i) {
      if (!_hidden[i]) {
        visibleCols.push(i + 1);
        seriesOpt[si] = { color: _colors[i % _colors.length], lineWidth: 2 };
        si++;
      }
    });
    var view = new google.visualization.DataView(_data);
    view.setColumns(visibleCols);
    _chart.draw(view, {
      title: 'Km cumulativi per anno',
      backgroundColor: { fill: bgColor },
      titleTextStyle: { color: titleColor, fontSize: 14 },
      curveType: 'function',
      legend: { position: 'bottom', textStyle: { color: textColor, fontSize: 12 } },
      chartArea: { width: '85%', height: '75%' },
      series: seriesOpt,
      hAxis: { textStyle: { fontSize: 12, color: textColor }, gridlines: { color: gridColor }, baselineColor: baseColor },
      vAxis: { textStyle: { fontSize: 12, color: textColor }, gridlines: { color: gridColor }, baselineColor: baseColor }
    });
  }

  var _rawRows = chartRows || [
    ['Gen', 0,6.7,78.6,0,50.8,22.6,108.5,233.6,189,211.9,171.7,30.3,136.6,247.7,238.8,254],
    ['Feb', 0,6.7,118.1,14.1,50.8,38.2,229.2,441.2,244.7,503.4,312,177.5,167.2,493.8,444.2,489.3],
    ['Mar', 0,6.7,161,65.4,50.8,92.6,310.3,736,372.9,672.6,460,370.8,285.1,800.1,737.5,737.3],
    ['Apr', 9.6,6.7,168.9,75.2,50.8,166.5,427.1,930.9,514.7,772,575.9,555,413.6,1037.1,1015.5,null],
    ['Mag', 9.6,6.7,174.9,116.9,66.1,236.1,576.6,1052.9,673.6,873.1,702.5,727.6,605.7,1255.5,1173.3,null],
    ['Giu', 9.6,6.7,174.9,199.5,147.3,268.3,642.3,1184.3,788.6,916.9,859,858.6,670,1518.6,1303,null],
    ['Lug', 9.6,6.7,181.9,292.1,240.3,341.1,716.2,1285.4,988.2,1051,1008.6,1019.6,861,1816.1,1529.8,null],
    ['Ago', 9.6,21.7,181.9,383.5,340.9,458.5,817.9,1461,1146.2,1191.3,1140.2,1131.7,1064.6,2075.7,1813.1,null],
    ['Set', 9.6,123.4,202.8,464.5,409.1,551.4,856.1,1603.9,1281.5,1295.2,1195,1372.9,1243.1,2340.6,2130.8,null],
    ['Ott', 9.6,178.5,209.9,549.7,509.9,656.7,1009.2,1806.4,1499.6,1446.7,1236.6,1574.9,1459.9,2599.6,2267.6,null],
    ['Nov', 9.6,226.5,209.9,604,599.2,751.4,1178.3,1966.9,1699.7,1592.4,1244.6,1815.3,1627,2866.4,2416.1,null],
    ['Dic', 9.6,233.5,209.9,618.2,680.7,802.5,1288.4,2159,1826.1,1757.5,1244.6,1927.8,1815.2,3139.3,2616.7,null]
  ];
  var _header = chartHeader || ["Mese","2011","2012","2013","2014","2015","2016","2017","2018","2019","2020","2021","2022","2023","2024","2025","2026"];

  google.charts.load('current', {'packages':['corechart']});
  google.charts.setOnLoadCallback(function() {
    var tableData = [_header].concat(_rawRows);
    _data = google.visualization.arrayToDataTable(tableData);
    _chart = new google.visualization.LineChart(document.getElementById('running-stats-chart'));
    drawChart();
    new MutationObserver(drawChart).observe(document.documentElement, { attributeFilter: ['class'] });
  });

  function toggleYear(i) {
    var visibleCount = _years.filter(function(year, k) { return !_hidden[k]; }).length;
    if (!_hidden[i]) { if (visibleCount === 1) return; }
    _hidden[i] = !_hidden[i];
    var btn = document.getElementById('btn-year-' + _years[i]);
    var color = _colors[i % _colors.length];
    btn.style.background = _hidden[i] ? 'transparent' : color;
    btn.style.color = _hidden[i] ? color : '#fff';
    drawChart();
  }
</script>
